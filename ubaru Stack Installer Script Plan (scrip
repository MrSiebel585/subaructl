#!/bin/bash

set -e

TARGET="/opt/subaru"

SOURCE="${1:-.}"

echo "Installing Subaru Stack from $SOURCE to $TARGET..."

sudo mkdir -p $TARGET

sudo rsync -av --exclude='.git*' --exclude='*.deb' $SOURCE/ $TARGET/

Dirs
sudo mkdir -p $TARGET/logging

Python venvs
cd $TARGET/imprezadash
sudo python3 -m venv .venv
sudo .venv/bin/pip install -r requirements.txt -r requirements-dev.txt

cd $TARGET/ecuextractor
sudo python3 -m venv .venv
sudo .venv/bin/pip install -r requirements.txt || true # if no reqs

cd $TARGET/wrxloggerwarningsystem
sudo python3 -m venv .venv
sudo .venv/bin/pip install -r requirements.txt

Build FastECU
cd $TARGET/FastECU
sudo apt update
sudo apt install -y qtbase5-dev qttools5-dev-tools build-essential libusb-1.

