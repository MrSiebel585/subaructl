#!/bin/bash
#
# ecu_menu - Interactive menu for Subaru ECU tools
# Improved version with better structure and more options
#

# Configuration
MAC="${ELM327_MAC:-01:23:45:67:89:BA}"
RFCOMM_DEV="${RFCOMM_DEV:-/dev/rfcomm0}"
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Helper functions
print_header() {
    echo -e "${CYAN}${BOLD}======================================"
    echo -e " Subaru ECU Diagnostic Menu"
    echo -e "======================================${NC}"
}

print_option() {
    local num="$1"
    local desc="$2"
    echo -e " ${GREEN}[${num}]${NC} ${desc}"
}

print_suboption() {
    local desc="$1"
    echo -e "      ${desc}"
}

pause() {
    if [ -t 0 ]; then
        read -p "Press Enter to continue..."
    fi
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${YELLOW}Note: Some options require sudo (will prompt)${NC}"
    fi
}

# Menu functions
menu_pair_bluetooth() {
    echo -e "${YELLOW}Pairing and connecting to $MAC...${NC}"
    if [ -f "./supports/pair_connect_elm327.exp" ]; then
        sudo ./supports/pair_connect_elm327.exp
    else
        echo -e "${RED}pair_connect_elm327.exp not found!${NC}"
    fi
}

menu_bind_rfcomm() {
    echo -e "${YELLOW}Binding RFCOMM interface to $RFCOMM_DEV...${NC}"
    if [ -f "./supports/bind_rfcomm.sh" ]; then
        sudo ./supports/bind_rfcomm.sh
    else
        echo -e "${RED}bind_rfcomm.sh not found!${NC}"
    fi
}

menu_list_devices() {
    echo -e "${GREEN}Paired Bluetooth devices:${NC}"
    if command -v bluetoothctl &> /dev/null; then
        bluetoothctl paired-devices 2>/dev/null || echo "No devices paired"
    else
        echo "bluetoothctl not available"
    fi
    echo ""
    echo -e "${GREEN}Available serial ports:${NC}"
    ls -la /dev/tty* /dev/rfcomm* 2>/dev/null | head -20 || echo "No serial ports found"
    echo ""
    echo -e "${GREEN}Serial devices by ID:${NC}"
    ls -la /dev/serial/by-id/ 2>/dev/null || echo "No serial by-id devices"
}

menu_test_connection() {
    echo -e "${YELLOW}Testing OBD connection...${NC}"
    if [ -c "$RFCOMM_DEV" ]; then
        echo -e "${GREEN}$RFCOMM_DEV exists${NC}"
        echo "Testing with python OBD..."
        python3 -c "
import obd
conn = obd.OBD('$RFCOMM_DEV')
print('Status:', conn.status())
conn.close()
" 2>&1 || echo "OBD test failed (device may be busy)"
    else
        echo -e "${RED}$RFCOMM_DEV not found${NC}"
        echo "Make sure Bluetooth is connected first"
    fi
}

menu_launch_wrx_dash() {
    echo -e "${YELLOW}Launching WRX Dash dashboard...${NC}"
    if [ -f "./wrxdash/app.py" ]; then
        cd wrxdash
        SUBARU_ELM327_PORT="$RFCOMM_DEV" python3 app.py
    else
        echo -e "${RED}wrxdash/app.py not found!${NC}"
    fi
}

menu_launch_ssm_logger() {
    echo -e "${YELLOW}Launching SSM CSV logger...${NC}"
    if [ -f "./logging/ssm_logger_csv.py" ]; then
        python3 ./logging/ssm_logger_csv.py
    else
        echo -e "${RED}ssm_logger_csv.py not found!${NC}"
    fi
}

menu_launch_obdai() {
    echo -e "${YELLOW}Launching OBD AI Streamlit interface...${NC}"
    if [ -f "./obdai/run_streamlit_iface.py" ]; then
        cd obdai
        python3 run_streamlit_iface.py
    else
        echo -e "${RED}run_streamlit_iface.py not found!${NC}"
    fi
}

menu_ecu_extractor() {
    echo -e "${YELLOW}ECU Extractor tools${NC}"
    echo "Available tools:"
    echo "  1) Extract ROM (cli.py)"
    echo "  2) Compare ROMs (diff_cli.py)"
    echo "  3) Safety Audit"
    echo "  4) Batch Analysis"
    read -p "Choose [1-4]: " ecu_choice
    
    case "$ecu_choice" in
        1)
            read -p "ROM file path: " rom_path
            if [ -f "$rom_path" ]; then
                python3 ecu_extractor/cli.py "$rom_path" --defs definitions/ecu_defs.xml
            else
                echo -e "${RED}ROM file not found!${NC}"
            fi
            ;;
        2)
            echo "Diff comparison - provide two ROM JSON files"
            ;;
        3)
            read -p "ROM directory: " rom_dir
            if [ -d "$rom_dir" ]; then
                python3 ecu_extractor/safety_cli.py "$rom_dir"
            else
                echo -e "${RED}Directory not found!${NC}"
            fi
            ;;
        *)
            echo "Cancelled"
            ;;
    esac
}

menu_view_logs() {
    echo -e "${YELLOW}Recent log files:${NC}"
    find . -name "*.csv" -type f -mtime -7 2>/dev/null | head -10
    echo ""
    echo -e "${YELLOW}Log directory:${NC}"
    LOG_DIR="${SUBARU_LOG_DIR:-/home/wrx/logs}"
    ls -la "$LOG_DIR" 2>/dev/null || echo "Log directory not found"
}

menu_system_info() {
    echo -e "${CYAN}System Information${NC}"
    echo "============================"
    echo -e "${GREEN}Kernel:${NC} $(uname -r)"
    echo -e "${GREEN}User:${NC} $(whoami)"
    echo -e "${GREEN}Bluetooth:${NC}"
    rfkill list bluetooth 2>/dev/null || echo "  Bluetooth not available"
    echo ""
    echo -e "${GREEN}Python:${NC} $(python3 --version)"
    echo -e "${GREEN}Key Python packages:${NC}"
    python3 -c "import obd; print('  obd:', obd.__version__)" 2>/dev/null || echo "  obd: not installed"
    python3 -c "import serial; print('  serial:', serial.VERSION)" 2>/dev/null || echo "  serial: not installed"
    python3 -c "import flask; print('  flask:', flask.__version__)" 2>/dev/null || echo "  flask: not installed"
}

menu_doctor() {
    echo -e "${CYAN}Running diagnostics...${NC}"
    echo "================================"
    
    # Check devices
    echo -e "\n${GREEN}1. Device Check:${NC}"
    ls /dev/ttyACM* /dev/ttyUSB* /dev/rfcomm* 2>/dev/null || echo "  No OBD devices found"
    ls /dev/serial/by-id/ 2>/dev/null | head -5 || echo "  No serial by-id devices"
    
    # Check Bluetooth
    echo -e "\n${GREEN}2. Bluetooth Check:${NC}"
    if command -v bluetoothctl &> /dev/null; then
        echo "  Paired devices:"
        bluetoothctl paired-devices 2>/dev/null | head -5 || echo "    None"
    else
        echo "  bluetoothctl not available"
    fi
    
    # Check Python deps
    echo -e "\n${GREEN}3. Python Dependencies:${NC}"
    python3 -c "import obd; print('  ✓ obd')" 2>/dev/null || echo "  ✗ obd (pip install python-OBD)"
    python3 -c "import serial; print('  ✓ serial')" 2>/dev/null || echo "  ✗ serial (pip install pyserial)"
    python3 -c "import flask; print('  ✓ flask')" 2>/dev/null || echo "  ✗ flask (pip install flask)"
    python3 -c "import socketio; print('  ✓ socketio')" 2>/dev/null || echo "  ✗ socketio (pip install python-socketio)"
    
    # Check permissions
    echo -e "\n${GREEN}4. Permissions:${NC}"
    if groups | grep -q dialout; then
        echo "  ✓ User in dialout group"
    else
        echo "  ✗ User NOT in dialout group"
        echo "    Run: sudo usermod -aG dialout \$USER"
    fi
    
    echo -e "\n${GREEN}Diagnostics complete!${NC}"
}

menu_alerts_config() {
    echo -e "${YELLOW}Opening Alerts configuration in browser...${NC}"
    echo "Make sure wrxdash is running first!"
    echo "URL: http://localhost:8080/alerts"
}

# Main loop
main() {
    check_root
    
    while true; do
        clear
        print_header
        
        echo -e "${BOLD}Connection Status:${NC}"
        if [ -c "$RFCOMM_DEV" ]; then
            echo -e "  ${GREEN}●${NC} RFCOMM device: $RFCOMM_DEV (available)"
        else
            echo -e "  ${RED}○${NC} RFCOMM device: $RFCOMM_DEV (not found)"
        fi
        
        echo ""
        print_option "1" "Pair & Connect ELM327 Bluetooth"
        print_option "2" "Bind RFCOMM to $RFCOMM_DEV"
        print_option "3" "List Bluetooth & Serial Devices"
        print_option "4" "Test OBD Connection"
        echo ""
        print_option "5" "Launch WRX Dash Dashboard"
        print_option "6" "Launch SSM CSV Logger"
        print_option "7" "Launch OBD AI Interface"
        print_option "8" "ECU Extractor Tools"
        print_option "9" "View Recent Logs"
        echo ""
        print_option "10" "System Info & Diagnostics"
        print_option "11" "Alerts Configuration (Web UI)"
        echo ""
        print_option "0" "Exit"
        echo ""
        
        read -p "Choose an option [0-11]: " choice
        
        case "$choice" in
            1) menu_pair_bluetooth ;;
            2) menu_bind_rfcomm ;;
            3) menu_list_devices ;;
            4) menu_test_connection ;;
            5) menu_launch_wrx_dash ;;
            6) menu_launch_ssm_logger ;;
            7) menu_launch_obdai ;;
            8) menu_ecu_extractor ;;
            9) menu_view_logs ;;
            10) menu_system_info; menu_doctor ;;
            11) menu_alerts_config ;;
            0) 
                echo -e "${GREEN}Goodbye!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid choice.${NC}"
                sleep 1
                ;;
        esac
        pause
    done
}

# Run main
main

